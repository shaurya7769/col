# ============================================
# Escape Skate Platform — Environment Variables
# ============================================

# REQUIRED: Secret for signing JWT tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_64_character_super_secret_jwt_key_here_change_this

# Server port (default: 5000)
PORT=5000

# Environment: development | production
NODE_ENV=development

# Comma-separated allowed CORS origins (not needed when frontend served by Express)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# SQLite database path (default: backend/data/escape.db)
DB_PATH=data/escape.db

# Upload directory (default: backend/uploads/)
UPLOAD_DIR=

# Base URL for uploaded file URLs (e.g. https://escape.example.com)
BASE_URL=http://localhost:5000

# Resend Email API key (optional — OTP codes logged to console without it)
# Sign up at https://resend.com/
RESEND_API_KEY=
RESEND_FROM_EMAIL=Escape <onboarding@resend.dev>

# Rate limiting (optional defaults)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=10
